# Copy to .env.local and fill in real values.
# Never commit .env.local — it is gitignored.

# Neon Postgres pooled connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# Long random hex string used to sign session cookies.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="replace-with-64-hex-chars"

# Bearer token for the BoardGameGeek XML API2.
# Required only when running `npm run bgg-refresh` to auto-populate src/data/bgg.json.
# Obtain by registering your app at the BGG XML API authorization page.
BGG_TOKEN=""

# Web Push VAPID keys (generate with: npx web-push generate-vapid-keys --json).
# Both PUBLIC and NEXT_PUBLIC variant are needed: the second one ships to the
# client. The same values should be set on Vercel for production.
VAPID_PUBLIC_KEY=""
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:you@example.com"
